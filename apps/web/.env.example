# Copy to `.env.local` in this folder (apps/web) for Next.js.
# Full monorepo template: ../../.env.example
# Parsed keys: src/lib/env.ts (serverEnv + clientEnv)

# --- NEXT_PUBLIC_* (clientEnv) ---
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOURCERER_PROGRAM_ID=
NEXT_PUBLIC_BSC_CHAIN_ID=97
NEXT_PUBLIC_BSC_RPC=https://bsc-testnet-rpc.publicnode.com
NEXT_PUBLIC_SOURCERER_BSC_FACTORY=
NEXT_PUBLIC_WALLETCONNECT_ID=

# --- Server — LLM for “AI Generate” (name, ticker, lore, prompts) ---
# OpenRouter = preferred chat model. If set, concepts do NOT use OpenAI’s chat API.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_APP_NAME=

# OpenAI: GPT chat for concepts only when OpenRouter is NOT set (no images — use Decart below).
OPENAI_API_KEY=

# --- Server — images (Decart only; OpenRouter/OpenAI do not generate images) ---
DECART_API_KEY=

# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# WEB3_STORAGE_TOKEN=

AUTH_SECRET=dev-only-change-me
# SOURCERER_PROGRAM_ID=
# SOURCERER_BSC_FACTORY=

# --- Server — Exa search for meme coin news ---
EXA_API_KEY=
