{
  "name": "@sourcerer/indexer",
  "version": "0.1.0",
  "private": true,
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "cron:news": "tsx src/cron/news.ts",
    "cron:graduate": "tsx src/cron/graduator.ts",
    "bsc:poll": "tsx src/bsc/poll.ts",
    "typecheck": "tsc --noEmit",
