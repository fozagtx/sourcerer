# Images: Decart first, then OpenAI DALL·E, then Replicate (posters)
DECART_API_KEY=
REPLICATE_API_TOKEN=
# Set to 1 only for local dev without OpenAI (placeholder concept text — not production)
# SOURCERER_AI_DEMO_MODE=1

