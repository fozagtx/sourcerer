DATABASE_URL=postgresql://sourcerer:sourcerer@localhost:5432/sourcerer

# ---- AI (Launch bay) — apps/web/src/lib/env.ts (serverEnv) ----
# Concepts (text/JSON): OpenRouter if OPENROUTER_* set; else OpenAI chat needs OPENAI_API_KEY.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_HTTP_REFERER=https://yoursite.com
# OPENROUTER_APP_NAME=Sourcerer
# OPENAI_API_KEY: GPT concepts when no OpenRouter (images are Decart only — DECART_API_KEY).
OPENAI_API_KEY=
# Images: Decart only (DECART_API_KEY)
DECART_API_KEY=

